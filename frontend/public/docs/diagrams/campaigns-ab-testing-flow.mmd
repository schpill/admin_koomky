flowchart LR
    subgraph A/B Testing Campaign Flow with CRM Integration
        direction LR

        A[Start: Define A/B Test Goal & Hypothesis]

        subgraph 1. Planning & Setup
            A --> B[Identify Target Audience];
            B -- "CRM: Segmentation & List Mgmt" --> CRMA(CRM: Audience Module);
            B --> C[Create Test Variants (A & B)];
            C -- "CRM: Content Library & Templates" --> CRMC(CRM: Content Management);
            C --> D[Configure A/B Test Parameters (Split, Duration)];
            D -- "CRM: Test Setup & Automation Rules" --> CRMD(CRM: Marketing Automation Platform);
        end

        subgraph 2. Execution & Monitoring
            D --> E[Launch Campaign with A/B Test];
            E -- "CRM: Campaign Activation & Scheduling" --> CRME(CRM: Campaign Execution Engine);
            E --> F[Monitor Performance & Collect Data];
            F -- "CRM: Activity Tracking & Dashboards" --> CRMF(CRM: Analytics & Reporting);
        end

        subgraph 3. Analysis & Action
            F --> G[Analyze Results & Statistical Significance];
            G --> H{Is there a clear winner (A or B)?};

            H -- Yes --> I[Implement Winning Variant];
            I -- "CRM: Update Live Campaigns / Assets" --> CRMI(CRM: Campaign Management System);
            I --> J[Document Learnings & Outcomes];
            J -- "CRM: Campaign History & Knowledge Base" --> CRMJ(CRM: Learnings Repository);
            J --> End((End: Test Concluded));

            H -- No (Inconclusive) --> K{Iterate or Conclude Test?};
            K -- Iterate --> D;
            K -- Conclude --> J;
        end
    end
graph TD
    A[Lead Captured / Interest Expressed] --> B(CRM: Create Lead / Contact Record);
    B --> C(CRM: Assign Lead Source & Initial Score);
    C --> D[CRM: Trigger Drip Campaign A];

    subgraph Drip Campaign A: Nurture Sequence
        E[Send Email #1: Welcome & Value Prop] --> F{User Action on Email #1?};
        F -- Clicks CTA / Converts --> G[CRM: Lead Qualifies (MQL)];
        F -- Engages (Open, Clicks) --> H(CRM: Increment Lead Score);
        F -- No Action (Timeout) --> I(CRM: Decrement Lead Score);
        F -- Unsubscribes --> J[CRM: Mark Opt-Out / Stop All Drips];

        H --> K{Next Email in Sequence Available?};
        I --> L{Inactivity Threshold Reached?};

        K -- Yes --> M[Send Next Email in Sequence];
        M --> F; %% Loop back for user action on subsequent emails

        K -- No --> Z[End Drip: Sequence Complete / No Conversion];

        L -- No --> M; %% Continue sending next email if not past inactivity threshold
        L -- Yes --> N[CRM: Update Lead Status: Cold];
    end

    G --> P[CRM: Create Sales Task / Update Status: SQL];
    P --> Q[CRM: Create Opportunity];
    Q --> R{Sales Opportunity Won?};
    R -- Yes --> S[CRM: Update Status: Customer];
    R -- No --> T[CRM: Update Status: Lost / Nurture B (Re-Engagement)];

    S --> U[CRM: Trigger Onboarding Flow];
    U --> V[End Flow];
    T --> V;
    N --> V;
    J --> V;
    Z --> V;
graph TD
    start_node((Start)) --> A[Prospect Identified];

    A --> B{CRM: Qualify Lead / Research};
    B --> C[CRM: Initial Outreach (Call/Email)];

    C --> D{CRM: Prospect Engaged?};
    D -- No --> E[CRM: Set Nurture Track];
    D -- Yes --> F[CRM: Schedule Discovery Call];

    F --> G[CRM: Conduct Discovery & Needs Assessment];
    G --> H{CRM: Lead Qualified?};

    H -- No --> E;
    H -- Yes --> I[CRM: Create Opportunity];

    I --> J[CRM: Develop Warmup Plan];
    J --> K[CRM: Present Warmup Plan];

    K --> L{CRM: Plan Accepted?};
    L -- No --> M[CRM: Opportunity Lost / Re-evaluate];
    L -- Yes --> N[CRM: Transition to Next Stage / Onboarding];

    E --> O(CRM: Ongoing Nurturing Activities);
    M --> end_node((End));
    N --> end_node;
    O --> end_node;

    subgraph CRM Lead Management Process
        A
        B
        C
        D
        E
        F
        G
        H
        O
    end

    subgraph CRM Opportunity Management Process
        I
        J
        K
        L
        M
        N
    end
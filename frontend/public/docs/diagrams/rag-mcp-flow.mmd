flowchart TD
    subgraph User & Application Interface
        A[Start: User Initiates Query] --> B(Application Frontend/UI);
    end

    subgraph RAG Multi-Cloud Platform (MCP) Flow
        B -- Query Request --> C{RAG Orchestration Service};

        C --> D[1. Query Pre-processing (NLP & Embedding)];
        D --> E[2. Context Retrieval from Knowledge Base];

        subgraph Data & Retrieval Subsystems
            E -- Request Embeddings/Search --> G[Retrieval Service];
            G -- Query Vector DB --> F[Knowledge Base (Vector DB/Enterprise Data)];
            F -- Return Relevant Chunks --> G;
            G -- Pass Chunks --> E;
        end

        E --> H[3. Prompt Augmentation (Query + Context)];
        H --> I[4. LLM Inference Request];

        subgraph Large Language Model (LLM) Service
            I -- API Call --> J[LLM Service (e.g., OpenAI, Anthropic, Custom Model)];
            J -- Generated Draft Response --> I;
        end

        I --> K[5. Response Post-processing (Validation & Formatting)];
    end

    subgraph Final Output
        K -- Final Response --> L(Application Frontend/UI);
        L --> M[End: Deliver Response to User];
    end
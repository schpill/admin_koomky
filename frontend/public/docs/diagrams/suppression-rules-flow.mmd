flowchart TD
    start((Start)) --> trigger[Event Trigger: Marketing Campaign Send / Data Import];

    trigger -- Campaign Initiated --> identify_audience[Identify Target Audience (e.g., Campaign Members, Leads)];
    trigger -- Data Imported --> identify_audience;

    identify_audience --> load_rules[Load Active Suppression Rules & Criteria];
    load_rules --> rule_db{"Suppression Rule Database"};

    load_rules --> iterate_records{FOR EACH Record in Target Audience};

    iterate_records --> evaluate_record{Is Record Suppressed by ANY Rule?};

    evaluate_record -- YES --> set_suppressed[Set Record Status: 'Suppressed'];
    set_suppressed --> log_reason[Log Suppression Event & Reason in CRM];
    log_reason --> exclude_comm[Exclude Record from Current Communication/Processing];
    exclude_comm --> end_record(Record Processed);

    evaluate_record -- NO --> set_eligible[Set Record Status: 'Eligible'];
    set_eligible --> proceed_comm[Proceed with Communication/Processing];
    proceed_comm --> end_record;

    end_record -- Next Record --> iterate_records;
    iterate_records -- All Records Processed --> final_end((End));
flowchart TD
    subgraph "1. Lead Generation & Capture"
        A[Start] --> B(Lead Source: Website, Ads, Referrals, Events)
        B --> C[CRM: Lead Capture & Entry]
    end

    subgraph "2. Lead Qualification"
        C --> D[CRM: Data Enrichment & Auto-Scoring]
        D --> E{Manual Review & Initial Contact}
        E -- "Not Qualified" --> F[CRM: Lead Nurturing Campaigns]
        F --> G{Nurtured Lead MQL?}
        G -- "No" --> F
        E -- "Qualified (MQL)" --> H[CRM: Update Lead Status to MQL]
        G -- "Yes" --> H
    end

    subgraph "3. Sales Acceptance"
        H --> I{Sales Qualified Lead (SQL)?}
        I -- "No, Re-nurture" --> F
        I -- "Yes, Assign" --> J[CRM: Assign to Sales Rep (SQL Status)]
    end

    subgraph "4. Opportunity Management"
        J --> K[CRM: Convert Lead to Opportunity]
        K --> L[CRM: Create Account & Contact Records]
        L --> M{Opportunity Stage: Discovery / Needs Analysis}
        M --> N{Opportunity Stage: Solution Proposal / Demo}
        N --> O{Opportunity Stage: Negotiation / Final Quote}
    end

    subgraph "5. Deal Closure"
        O -- "Closed Won" --> P[CRM: Update Opportunity Status]
        P --> Q[CRM: Handoff to Onboarding/Success Team]
        Q --> R(End)

        O -- "Closed Lost" --> S[CRM: Update Opportunity Status to Lost]
        S --> T[CRM: Log Lost Reasons / Post-Mortem]
        T --> U[CRM: Re-engagement Strategy / Archives]
        U --> R
    end

    %% Styles for better documentation quality
    classDef start_end fill:#DDF,stroke:#333,stroke-width:2px,color:#333;
    classDef process fill:#FFF,stroke:#AAA,stroke-width:1px,color:#333;
    classDef decision fill:#FFDDC2,stroke:#FF9933,stroke-width:1px,color:#333;
    classDef crm_action fill:#E6FFCC,stroke:#66AA33,stroke-width:1px,color:#333;
    classDef crm_status fill:#CCE5FF,stroke:#3366AA,stroke-width:1px,color:#333;
    classDef external fill:#FFF,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5,color:#333;

    class A,R start_end;
    class B external;
    class C,D,F,H,J,K,L,P,Q,S,T,U crm_action;
    class E,G,I,M,N,O decision;
graph TD
    A((Start)) --> B[Request Setting Change/New Setting <br> <i>(User/System Trigger)</i>];

    B --> C{Is Request Documented <br> in CRM?};

    C -- No --> D[<b>Create CRM Record:</b> <br> Setting Change Request];
    D --> E[Define Requirements & Justification <br> <i>(Attach to CRM Record)</i>];

    C -- Yes --> E;

    E --> F[Technical Analysis & Impact Assessment];
    F --> G[<b>Update CRM Record:</b> <br> Analysis Complete & Recommended Action];

    G --> H[Stakeholder Review <br> <i>(Security, Legal, Business)</i>];
    H --> I{Stakeholders Approve <br> Proposed Setting?};

    I -- No --> J[<b>Update CRM Record:</b> <br> Request Rejected/Requires Rework <br> <i>(Document Reasons)</i>];
    J --> E; /* Loop back for rework or new iteration */

    I -- Yes --> K[Formal Approval <br> <i>(e.g., Governance Committee)</i>];
    K --> L{Formal Approval <br> Obtained?};

    L -- No --> M[<b>Update CRM Record:</b> <br> Request Denied (Final) <br> <i>(Document Reasons)</i>];
    M --> Z((End)); /* Final denial */

    L -- Yes --> N[<b>Update CRM Record:</b> <br> Approved, Ready for Implementation];
    N --> O[Implement Setting Change <br> <i>(Configuration/Code Deployment)</i>];

    O --> P[Verify & Test Implementation];
    P --> Q{Implementation Verified <br> & Functioning?};

    Q -- No --> R[<b>Update CRM Record:</b> <br> Implementation Failed/Requires Rework <br> <i>(Document Issues)</i>];
    R --> O; /* Loop back for rework */

    Q -- Yes --> S[<b>Update CRM Record:</b> <br> Implemented Setting Details & Configuration <br> <i>(Final Documentation)</i>];
    S --> T[Monitor & Audit Setting Effectiveness <br> <i>(Ongoing Checks)</i>];
    T --> U[Periodic Review & Re-evaluation <br> <i>(Scheduled Governance)</i>];

    U --> V{Re-evaluation Triggers <br> New Action?};
    V -- Yes --> B; /* Loop back to trigger new request/change */
    V -- No --> W[<b>Update CRM Record:</b> <br> Setting Stable, No Action Needed <br> <i>(Close Review Cycle)</i>];
    W --> Z((End));

    Z((End));

    subgraph CRM Documentation & Tracking
        D
        G
        J
        M
        N
        R
        S
        W
    end
graph TD
    A[Ticket Submitted] --> B{Initial Triage & Assignment};
    B --> C[Agent Acknowledges & Reviews Ticket];
    C --> D[Investigate Issue & Diagnose Problem];
    D --> E{Solution Found in KB or Prior Cases?};

    E -- Yes --> F[Propose Solution to Customer];
    E -- No --> G[Escalate to Tier 2/SME];
    G --> H[Tier 2 Investigates & Provides Solution];
    H --> F;

    F --> I{Customer Confirms Resolution?};
    I -- Yes --> J[Ticket Resolved & Closed];
    I -- No (Requires Further Action) --> D;

    J --> K[Update Knowledge Base (if applicable)];
    J --> L{Customer Reopens Ticket (within X days)?};
    L -- Yes --> C;
    L -- No --> M[Ticket Archived & Process Ends];

    style A fill:#DDEBF7,stroke:#367DD9,stroke-width:2px;
    style M fill:#DDEBF7,stroke:#367DD9,stroke-width:2px;
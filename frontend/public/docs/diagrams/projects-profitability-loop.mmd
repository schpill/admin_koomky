graph TD
    A[Start] --> B(Project Opportunity Identification);

    subgraph CRM Documentation Quality Influence
        C{CRM Data Quality for Proposal?}
        C -- High Quality --> D(Accurate Project Proposal);
        C -- Low Quality --> E(Risk: Inaccurate Proposal / Scope Creep);
    end

    B --> C;
    D --> F(Project Planning & Resource Allocation);
    E --> F;

    F --> G(Project Execution);
    G --> H(Project Monitoring & Cost Tracking);
    H --> I(Project Completion & Invoicing);
    I --> J(Profitability Analysis);

    subgraph Continuous Improvement Loop
        K(Lessons Learned & Performance Review);
        J --> K;
        K --> L(Identify CRM Documentation Gaps);
        L --> M(Update CRM Data & Improve Documentation Standards);
    end

    M --> B;
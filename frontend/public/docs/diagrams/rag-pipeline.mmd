graph TD
    subgraph CRM Documentation Ingestion (Offline Process)
        A[CRM Documentation Source] --> B{Parse & Clean Docs}
        B --> C[Chunk Text]
        C --> D[Embed Chunks]
        D --> E[Vector Database]
    end

    subgraph RAG Pipeline (Online Query Process)
        F[User Query] --> G[Embed Query]
        G --> H{Retrieve Relevant Chunks}
        H --> E
        E -- Context Chunks --> H
        H --> I[Augment Prompt]
        F -- Original Query --> I
        I --> J[Large Language Model (LLM)]
        J --> K[Generated Answer]
    end

    subgraph Quality Feedback Loop
        K --> L[User Feedback]
        K --> M{Quality Monitor & Evaluation}
        L --> M

        M -- Identified Doc Gaps/Errors --> N[CRM Doc Improvement Team]
        N -- Updated Documentation --> A

        M -- System Tuning Suggestions --> O[RAG System Optimizer]
        O -- Retrieval/Generation Updates --> G, J, H
    end

    style A fill:#E0F2F7,stroke:#66BB6A,stroke-width:2px
    style E fill:#D1C4E9,stroke:#673AB7,stroke-width:2px
    style J fill:#FFF9C4,stroke:#FBC02D,stroke-width:2px
    style K fill:#C8E6C9,stroke:#388E3C,stroke-width:2px
    style N fill:#FFE0B2,stroke:#FB8C00,stroke-width:2px
    style O fill:#FFCDD2,stroke:#E53935,stroke-width:2px
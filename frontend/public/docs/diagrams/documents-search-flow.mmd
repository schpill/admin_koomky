flowchart TD
    A[Start: User Initiates Document Search] --> B[/Enter Search Query & Filters/];

    subgraph User Interface
        B
        C[Submit Search Request]
        H[Display Search Results]
        J{Result Satisfactory?}
        K[User Selects Document]
        M[Display "Access Denied"]
        N[Open Document / Download]
    end

    subgraph Backend Systems
        C --> D{Search Orchestrator};
        D -- Query DMS --> E1((Document Management System));
        D -- Query CRM --> E2((CRM Files & Notes));
        D -- Query KB --> E3((Knowledge Base System));

        E1 & E2 & E3 --> F[Aggregate & Rank Results];
        F --> G[Apply Security Trimming & Permissions];
        G --> H;
        H --> J;
        J -- Yes --> K;
        J -- No --> B;

        K --> L{Check Document Specific Permissions};
        L -- Denied --> M;
        L -- Granted --> N;

        N --> O[Log Search & Access Activity in CRM];
        M --> O;
    end

    O --> P[End: Search Flow Completed];
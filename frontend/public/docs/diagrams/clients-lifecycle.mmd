stateDiagram-v2
    direction LR

    state "Client Lifecycle" as ClientLifecycle {

        state "1. Lead Generation" as LeadGen {
            state "Prospect Identification"
            state "Initial Contact & Data Capture"
            note right of Initial Contact & Data Capture
                **CRM Quality Focus:**
                - Accurate initial contact info (source, referrer)
                - Consistent data entry (no duplicates, standard fields)
                - Consent management recorded
            end note
        }

        LeadGen --> Qualification

        state "2. Qualification" as Qualification {
            state "Needs Assessment"
            state "Fit Evaluation"
            note right of Fit Evaluation
                **CRM Quality Focus:**
                - Detailed needs/pain points recorded
                - Qualification criteria clearly documented
                - Competitor interactions noted
                - Next steps & responsible parties assigned
            end note
        }

        Qualification --> Proposal

        state "3. Proposal & Negotiation" as Proposal {
            state "Solution Design & Offer"
            state "Terms Discussion & Agreement"
            note right of Terms Discussion & Agreement
                **CRM Quality Focus:**
                - All communication logs (emails, calls) summarized/attached
                - Proposal versions, revisions & terms tracked
                - Decision-makers & influencers accurately identified
                - Key objections and resolutions recorded
            end note
        }

        Proposal --> Onboarding

        state "4. Onboarding" as Onboarding {
            state "Account Setup"
            state "Service Activation & Initial Training"
            note right of Service Activation & Initial Training
                **CRM Quality Focus:**
                - Service agreements, contracts linked & accessible
                - Implementation tasks assigned, tracked & completed
                - Key client contacts & roles accurately entered
                - Welcome pack/resource delivery confirmed
            end note
        }

        Onboarding --> ActiveClient

        state "5. Active Client Engagement" as ActiveClient {
            state "Service Delivery"
            state "Support & Maintenance"
            state "Relationship Management"
            note right of Relationship Management
                **CRM Quality Focus:**
                - Support tickets, incidents logged & resolved with detail
                - Interaction history (meetings, calls, notes) summarized
                - Project/service status & deliverables updated consistently
                - Client feedback (positive/negative) captured
            end note
        }

        ActiveClient --> RetentionGrowth

        state "6. Retention & Growth" as RetentionGrowth {
            state "Value Realization & Feedback"
            state "Upsell/Cross-sell Opportunities"
            state "Contract Renewal"
            note right of Contract Renewal
                **CRM Quality Focus:**
                - Client satisfaction scores (NPS, CSAT) recorded
                - Upsell/cross-sell opportunities identified & tracked
                - Account plans & strategic reviews documented
                - Renewal status & terms accurately updated
                - Client testimonials/case study potential noted
            end note
        }

        RetentionGrowth --> Offboarding

        state "7. Offboarding / Churn" as Offboarding {
            state "Account Closure Procedures"
            state "Feedback & Data Archiving"
            note right of Feedback & Data Archiving
                **CRM Quality Focus:**
                - Reasons for churn/offboarding documented thoroughly
                - Exit survey results/feedback captured comprehensively
                - Data archiving/deletion status confirmed & compliant
                - Account closure tasks tracked & completed
                - Learnings for future process improvement recorded
            end note
        }

        Offboarding --> [*]
    }
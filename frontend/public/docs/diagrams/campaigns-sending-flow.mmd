graph TD
    %% Start of the Campaign Sending Flow
    start((Start Campaign Sending Flow)) --> A;

    %% Phase 1: Campaign Setup & Design (User-driven actions within CRM)
    subgraph Campaign Setup & Design
        A[Create & Configure Campaign Details]
        B{Select Target Audience & Segments}
        C[Design & Personalize Content (Email, SMS, etc.)]
        D[Define Schedule & Sending Options]

        A --> B;
        B --> C;
        C --> D;
    end

    %% Phase 2: Internal Review & Approval Process
    subgraph Internal Review & Approval
        D --> E{Internal Review & Approval Required?};
        E -- Yes --> F{Campaign Approval Status};
        F -- Approved --> G;
        F -- Rejected --> D; %% Loop back for corrections and resubmission
        E -- No --> G; %% Directly proceed if no approval needed
    end

    %% Phase 3: Pre-Send System Validation & Queueing
    subgraph Pre-Send System Validation
        G(System Pre-send Validation)
        H[Campaign Added to Sending Queue]

        G --> H;
    end

    %% Phase 4: Message Dispatch & Delivery
    subgraph Message Dispatch & Delivery
        H --> I[Trigger Send Event];
        I --> J[ESP / MTA Processes & Dispatches Messages];
        J --> K{Delivery Status Received & Processed};
    end

    %% Phase 5: Post-Send Tracking, Bounce Handling & Reporting
    subgraph Post-Send Tracking & Reporting
        K -- Delivered --> L[Track Opens, Clicks, & Conversions];
        K -- Hard Bounce / Failure --> M_hard[Update CRM: Flag Hard Bounce / Permanent Failure];
        K -- Soft Bounce --> M_soft[Update CRM: Flag Soft Bounce / Temporary Failure];
        K -- Spam Complaint --> M_spam[Update CRM: Flag Spam Complaint / Opt-out];

        L --> N[Log All Activity to CRM Contact History];
        M_hard --> N;
        M_soft --> N;
        M_spam --> N;

        N --> O[Generate Campaign Performance Reports];
        O --> end((End Campaign Sending Flow));
    end
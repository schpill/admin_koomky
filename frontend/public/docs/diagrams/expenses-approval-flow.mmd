flowchart TD
    subgraph Employee Actions
        A[Submit Expense Report] --> B{Completeness & Policy Check?};
        B -- No --> C[Notify Employee: Required Revisions];
        C --> A;
        B -- Yes --> D[Report Submitted for Approval];
    end

    subgraph Manager Approval
        D --> E{Manager Approval Required?};
        E -- No --> J; // Skip to Finance if not required
        E -- Yes --> F[Manager Reviews Expense Report];
        F --> G{Manager Approves?};
        G -- No --> H[Notify Employee & Manager: Rejection Reason];
        H --> A; // Employee revises & resubmits
        G -- Yes --> I[Report Sent to Finance for Review];
    end

    subgraph Finance Review & Payment Processing
        I --> J[Finance Reviews Expense Report & Receipts];
        J --> K{Finance Approves?};
        K -- No --> L[Notify Employee, Manager & Finance: Rejection Reason];
        L --> A; // Employee revises & resubmits
        K -- Yes --> M[Process Reimbursement via ERP/HRIS];
        M --> N[Reimbursement Issued];
        N --> O((End Flow));
    end